DATABASE_URL="file:./dev.db"
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# --- Live News (required for 50 daily stories) ---
# Get a free key at https://newsapi.org (free plan: 100 req/day, good for dev)
NEWS_API_KEY="your-newsapi-key-here"

# --- Daily Cron Protection (optional but recommended) ---
# Set any secret string. Pass it when calling /api/cron/refresh?secret=YOUR_SECRET
# CRON_SECRET="your-cron-secret"

# --- How to set up daily auto-refresh ---
# Option 1: cron job on your server
#   0 6 * * * curl "https://yourdomain.com/api/cron/refresh?secret=YOUR_SECRET"
#
# Option 2: free services (cron-job.org, EasyCron, GitHub Actions, etc.)
#   URL: https://yourdomain.com/api/cron/refresh?secret=YOUR_SECRET
#   Schedule: Once per day
#
# Option 3: Vercel Cron (vercel.json)
#   Add to vercel.json: { "crons": [{ "path": "/api/cron/refresh", "schedule": "0 6 * * *" }] }
